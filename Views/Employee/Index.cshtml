@model IEnumerable<EmployeeManagementSystem.Models.Employee>
@{
    ViewBag.Title = "Employee List";
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="display-6 fw-bold text-primary mb-0">
                <i class="bi bi-people-fill me-2"></i>Employees
            </h2>
            <p class="text-muted mt-1">Manage your company workforce</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Dashboard", "Employee")" class="btn btn-outline-secondary px-4 py-2 shadow-sm rounded-3">
                <i class="bi bi-arrow-left me-1"></i> Dashboard
            </a>
            <a href="@Url.Action("Create")" class="btn btn-primary px-4 py-2 shadow-sm rounded-3">
                <i class="bi bi-person-plus-fill me-2"></i>Add New Employee
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4 py-3 text-secondary fw-semibold">ID</th>
                            <th class="py-3 text-secondary fw-semibold">First Name</th>
                            <th class="py-3 text-secondary fw-semibold">Last Name</th>
                            <th class="py-3 text-secondary fw-semibold">Email</th>
                            <th class="py-3 text-secondary fw-semibold">Department</th>
                            <th class="py-3 text-secondary fw-semibold">Role</th>
                            <th class="py-3 text-secondary fw-semibold">Salary</th>
                            <th class="px-4 py-3 text-end text-secondary fw-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var e in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted">#@e.Id</td>
                                <td class="fw-medium">@e.FirstName</td>
                                <td class="fw-medium">@e.LastName</td>
                                <td>
                                    <a href="mailto:@e.Email" class="text-decoration-none text-primary">
                                        <i class="bi bi-envelope me-1"></i>@e.Email
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border px-2 py-1">
                                        <i class="bi bi-building me-1"></i>@e.DepartmentName
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info px-2 py-1">
                                        <i class="bi bi-person-workspace me-1"></i>@e.RoleTitle
                                    </span>
                                </td>
                                <td class="text-success fw-semibold">$@e.Salary.ToString("N0")</td>
                                <td class="px-4 text-end">
                                    <div class="btn-group shadow-sm rounded-3">
                                        <a href="@Url.Action("Edit", new { id=e.Id })" class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a href="@Url.Action("Details", new { id=e.Id })" class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="bi bi-info-circle"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", new { id=e.Id })" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>