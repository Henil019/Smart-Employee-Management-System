@model EmployeeManagementSystem.Models.Employee
@{
    ViewBag.Title = "Create Employee";
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="display-6 fw-bold text-primary mb-0">
                        <i class="bi bi-person-plus me-2"></i>Add Employee
                    </h2>
                    <p class="text-muted mt-1">Register a new team member</p>
                </div>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-3 shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    @using (Html.BeginForm()) 
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger rounded-3 p-3 mb-4" })

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-person me-1"></i> First Name
                                </label>
                                @Html.EditorFor(model => model.FirstName, new { htmlAttributes = new { @class = "form-control form-control-lg bg-light border-0" } })
                                @Html.ValidationMessageFor(model => model.FirstName, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-person-badge me-1"></i> Last Name
                                </label>
                                @Html.EditorFor(model => model.LastName, new { htmlAttributes = new { @class = "form-control form-control-lg bg-light border-0" } })
                                @Html.ValidationMessageFor(model => model.LastName, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-envelope me-1"></i> Email Address
                                </label>
                                @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control form-control-lg bg-light border-0", type="email" } })
                                @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-building me-1"></i> Department
                                </label>
                                @Html.DropDownListFor(model => model.DepartmentId, ViewBag.Departments as SelectList, "-- Select Department --", new { @class = "form-select form-select-lg bg-light border-0" })
                                @Html.ValidationMessageFor(model => model.DepartmentId, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-person-workspace me-1"></i> Role
                                </label>
                                @Html.DropDownListFor(model => model.RoleId, ViewBag.Roles as SelectList, "-- Select Role --", new { @class = "form-select form-select-lg bg-light border-0" })
                                @Html.ValidationMessageFor(model => model.RoleId, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-currency-dollar me-1"></i> Salary
                                </label>
                                @Html.EditorFor(model => model.Salary, new { htmlAttributes = new { @class = "form-control form-control-lg bg-light border-0", type="number", step="0.01" } })
                                @Html.ValidationMessageFor(model => model.Salary, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-calendar-date me-1"></i> Join Date
                                </label>
                                @Html.EditorFor(model => model.JoinDate, new { htmlAttributes = new { @class = "form-control form-control-lg bg-light border-0", type="date" } })
                                @Html.ValidationMessageFor(model => model.JoinDate, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold text-secondary">
                                    <i class="bi bi-key me-1"></i> Login Password
                                </label>
                                @Html.EditorFor(model => model.Password, new { htmlAttributes = new { @class = "form-control form-control-lg bg-light border-0", type="password" } })
                                @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger small mt-1" })
                            </div>

                            <div class="col-12">
                                <div class="form-check form-switch mt-2">
                                    @Html.CheckBoxFor(model => model.IsHR, new { @class = "form-check-input", role = "switch", id="IsHR" })
                                    <label class="form-check-label fw-semibold text-secondary" for="IsHR">
                                        <i class="bi bi-shield-lock me-1 text-warning"></i> Grant HR Dashboard Access (Manage own department)
                                    </label>
                                </div>
                            </div>

                            <div class="col-12 mt-5 text-end">
                                <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm rounded-3">
                                    <i class="bi bi-check-circle me-2"></i>Create Employee
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>