@model EmployeeManagementSystem.Models.Dashboard
@{
    ViewBag.Title = "Dashboard";
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="display-6 fw-bold text-primary mb-0">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </h2>
            <p class="text-muted mt-1">Welcome to the Employee Management System</p>
        </div>
        <div class="btn-group shadow-sm rounded-3">
            <a href="@Url.Action("Index")" class="btn btn-outline-primary px-4">
                <i class="bi bi-people-fill me-1"></i> Employees
            </a>
            <a href="@Url.Action("Logout", "Admin")" class="btn btn-outline-danger px-4">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </a>
        </div>
    </div>

    <!-- Statistics Cards Row -->
    <div class="row g-4 mb-5">
        <!-- Total Employee Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted text-uppercase small fw-bold mb-2">Total Employees</p>
                            <h2 class="display-5 fw-bold mb-0 text-primary">@Model.TotalEmployee</h2>
                        </div>
                        <div class="bg-light rounded-circle p-3">
                            <i class="bi bi-people fs-3 text-primary"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <small class="text-success fw-semibold">
                            <i class="bi bi-graph-up me-1"></i> Active workforce
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Highest Salary Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted text-uppercase small fw-bold mb-2">Highest Salary</p>
                            <h2 class="display-5 fw-bold mb-0 text-success">$@Model.HighestSalary.ToString("N0")</h2>
                        </div>
                        <div class="bg-light rounded-circle p-3">
                            <i class="bi bi-trophy fs-3 text-success"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <small class="text-muted fw-semibold">
                            <i class="bi bi-star-fill text-warning me-1"></i> Top performer
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Average Salary Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted text-uppercase small fw-bold mb-2">Average Salary</p>
                            <h2 class="display-5 fw-bold mb-0 text-info">$@Model.AvarageSalary.ToString("N0")</h2>
                        </div>
                        <div class="bg-light rounded-circle p-3">
                            <i class="bi bi-calculator fs-3 text-info"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <small class="text-muted fw-semibold">
                            <i class="bi bi-cash-stack me-1"></i> Company average
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Department Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted text-uppercase small fw-bold mb-2">Departments</p>
                            <h2 class="display-5 fw-bold mb-0 text-warning">@Model.TotalDepartment</h2>
                        </div>
                        <div class="bg-light rounded-circle p-3">
                            <i class="bi bi-building fs-3 text-warning"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <small class="text-muted fw-semibold">
                            <i class="bi bi-diagram-3 me-1"></i> Active departments
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold text-dark mb-4">
                <i class="bi bi-lightning-charge text-warning me-2"></i> Quick Actions
            </h5>
            <div class="d-flex flex-wrap gap-3">
                <a href="@Url.Action("Create")" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm">
                    <i class="bi bi-person-plus me-2"></i> Add New Employee
                </a>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4 py-2 rounded-3 shadow-sm">
                    <i class="bi bi-list-ul me-2"></i> Employee Directory
                </a>
                
                @if (Session["Role"] as string == "Admin")
                {
                    <a href="@Url.Action("Index", "Department")" class="btn btn-outline-secondary px-4 py-2 rounded-3 shadow-sm">
                        <i class="bi bi-building me-2"></i> Manage Departments
                    </a>
                    <a href="@Url.Action("Index", "Role")" class="btn btn-outline-secondary px-4 py-2 rounded-3 shadow-sm">
                        <i class="bi bi-person-workspace me-2"></i> Manage Roles
                    </a>
                }
            </div>
        </div>
    </div>
</div>