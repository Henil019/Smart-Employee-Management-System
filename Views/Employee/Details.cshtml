@model EmployeeManagementSystem.Models.Employee
@{
    ViewBag.Title = "Employee Details";
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <!-- Header Section -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="display-6 fw-bold text-primary mb-0">
                        <i class="bi bi-person-badge me-2"></i>Employee Details
                    </h2>
                    <p class="text-muted mt-1">View complete employee information</p>
                </div>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-3 shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>

            <!-- Employee Details Card -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-light border-0 pt-4 pb-3 px-4 rounded-top-4">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-person-circle text-primary me-3" style="font-size: 3rem;"></i>
                        <div>
                            <h3 class="mb-0 fw-bold text-dark">@Model.FirstName @Model.LastName</h3>
                            <p class="mb-0 text-muted">Employee ID: #@Model.Id</p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="table-responsive">
                        <table class="table table-borderless mb-0">
                            <tbody>
                                <tr>
                                    <td class="fw-semibold text-secondary" style="width: 180px;">
                                        <i class="bi bi-hash text-primary me-2"></i>Employee ID:
                                    </td>
                                    <td class="fw-bold">@Model.Id</td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold text-secondary">
                                        <i class="bi bi-person-fill text-primary me-2"></i>First Name:
                                    </td>
                                    <td class="fw-medium">@Model.FirstName</td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold text-secondary">
                                        <i class="bi bi-person-badge text-primary me-2"></i>Last Name:
                                    </td>
                                    <td class="fw-medium">@Model.LastName</td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold text-secondary">
                                        <i class="bi bi-envelope-fill text-primary me-2"></i>Email:
                                    </td>
                                    <td>
                                        <a href="mailto:@Model.Email" class="text-decoration-none">
                                            @Model.Email
                                        </a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold text-secondary">
                                        <i class="bi bi-building-fill text-primary me-2"></i>Department:
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-2 py-1">
                                            <i class="bi bi-briefcase-fill me-1 text-secondary"></i> @Model.DepartmentName
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold text-secondary">
                                        <i class="bi bi-person-workspace text-primary me-2"></i>Role:
                                    </td>
                                    <td>
                                        <span class="badge bg-info bg-opacity-10 text-info px-2 py-1">
                                            @Model.RoleTitle
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold text-secondary">
                                        <i class="bi bi-currency-dollar text-primary me-2"></i>Salary:
                                    </td>
                                    <td>
                                        <span class="fw-bold text-success fs-5">$@Model.Salary.ToString("N0")</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-semibold text-secondary">
                                        <i class="bi bi-calendar-date-fill text-primary me-2"></i>Join Date:
                                    </td>
                                    <td class="text-muted">
                                        @Model.JoinDate.ToString("MMMM dd, yyyy")
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <hr class="my-4 text-muted opacity-25" />

                    <!-- Quick Actions -->
                    <div class="d-flex justify-content-end gap-3">
                        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary px-4 shadow-sm rounded-3">
                            <i class="bi bi-pencil-square me-1"></i> Edit Record
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>