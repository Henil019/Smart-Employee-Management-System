@model EmployeeManagementSystem.Models.Role
@{
    ViewBag.Title = "Edit Role";
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="display-6 fw-bold text-primary mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Edit Role
                    </h2>
                </div>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-3 shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    @using (Html.BeginForm()) 
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.Id)
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger rounded-3 p-3 mb-4" })

                        <div class="mb-4">
                            <label class="form-label fw-semibold text-secondary">
                                <i class="bi bi-person-workspace me-1"></i> Role Title
                            </label>
                            @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control form-control-lg bg-light border-0" } })
                            @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger small mt-1" })
                        </div>

                        <div class="mt-5 text-end">
                            <button type="submit" class="btn btn-warning btn-lg px-5 shadow-sm rounded-3">
                                <i class="bi bi-check-circle me-2"></i>Save Changes
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
