@{
    ViewBag.Title = "AI Assistant";
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="display-6 fw-bold text-primary mb-0">
                        <i class="bi bi-robot me-2"></i>AI Assistant
                    </h2>
                    <p class="text-muted mt-1">Intelligent Helper for Employee Management</p>
                </div>
                <a href="@Url.Action("Dashboard", "Employee")" class="btn btn-outline-secondary px-4 py-2 shadow-sm rounded-3">
                    <i class="bi bi-arrow-left me-1"></i> Dashboard
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-5">
                    
                    <!-- Question Input Area -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold text-secondary">
                            <i class="bi bi-question-circle me-1"></i> Ask me anything about employees, attendance, or system help
                        </label>
                        <div class="input-group input-group-lg shadow-sm rounded-3">
                            <span class="input-group-text bg-light border-0">
                                <i class="bi bi-chat-text text-primary"></i>
                            </span>
                            <input type="text" id="question" class="form-control border-0 bg-light" placeholder="e.g., How many employees are there?" />
                            <button class="btn btn-primary px-4" onclick="askAI()">
                                <i class="bi bi-send me-1"></i> Ask AI
                            </button>
                        </div>
                    </div>

                    <!-- Result Display Area -->
                    <div class="card bg-light border-0 rounded-3">
                        <div class="card-body p-4" id="resultContainer" style="min-height: 120px;">
                            <div id="result" class="text-secondary" style="font-size: 16px; line-height: 1.6;">
                                <i class="bi bi-info-circle me-2 text-primary"></i>
                                Your AI response will appear here...
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Example Questions -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <p class="text-muted fw-semibold mb-3">
                        <i class="bi bi-lightbulb me-1 text-warning"></i> Try asking:
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="$('#question').val('Show me total employees'); askAI();">
                            <i class="bi bi-people me-1"></i> Total employees
                        </button>
                        <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="$('#question').val('Today\'s attendance summary'); askAI();">
                            <i class="bi bi-calendar-check me-1"></i> Today's attendance
                        </button>
                        <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="$('#question').val('Highest paid employee'); askAI();">
                            <i class="bi bi-trophy me-1"></i> Highest paid employee
                        </button>
                        <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="$('#question').val('Department wise employee count'); askAI();">
                            <i class="bi bi-building me-1"></i> Department count
                        </button>
                        <button class="btn btn-sm btn-outline-secondary rounded-pill" onclick="$('#question').val('Average salary'); askAI();">
                            <i class="bi bi-calculator me-1"></i> Average salary
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    function askAI() {

        var q = $("#question").val();

        $("#result").html('<div class="d-flex align-items-center text-primary fw-semibold"><div class="spinner-border spinner-border-sm me-2" role="status"></div> Thinking...</div>');

        $.ajax({
            url: "http://127.0.0.1:5000/ask",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify({ question: q }),

            success: function (response) {
                $("#result").html('<i class="bi bi-check-circle-fill text-success me-2"></i> <span class="text-dark">' + response.answer + '</span>');
            },

            error: function () {
                $("#result").html('<i class="bi bi-exclamation-triangle-fill text-danger me-2"></i> Error calling AI API. Please make sure the AI server is running.');
            }
        });
    }
</script>