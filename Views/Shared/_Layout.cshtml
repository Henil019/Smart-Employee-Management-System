<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    @if (Session["Admin"] != null)
    {
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
            <div class="container">
                @Html.ActionLink("EMS Admin", "Dashboard", "Employee", new { area = "" }, new { @class = "navbar-brand fw-bold" })
                <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @{ string role = Session["Role"] as string; }
                        
                        @if (role == "Admin" || role == "HR")
                        {
                            <li>@Html.ActionLink("Dashboard", "Dashboard", "Employee", new { area = "" }, new { @class = "nav-link" })</li>
                            <li>@Html.ActionLink("Employees", "Index", "Employee", new { area = "" }, new { @class = "nav-link" })</li>
                        }
                        else
                        {
                            <li><a href="@Url.Action("Details", "Employee", new { id = Session["EmployeeId"] })" class="nav-link">My Profile</a></li>
                        }

                        @if (role == "Admin")
                        {
                            <li>@Html.ActionLink("Departments", "Index", "Department", new { area = "" }, new { @class = "nav-link" })</li>
                            <li>@Html.ActionLink("Roles", "Index", "Role", new { area = "" }, new { @class = "nav-link" })</li>
                        }

                        <li>@Html.ActionLink("Attendance", "Index", "Attendance", new { area = "" }, new { @class = "nav-link" })</li>
                        
                        @if (role == "Admin" || role == "HR")
                        {
                            <li>@Html.ActionLink("AI Assistant", "Index", "AI", new { area = "" }, new { @class = "nav-link" })</li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        <li>
                            <a href="@Url.Action("Logout", "Admin")" class="btn btn-outline-light btn-sm mt-1">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - My ASP.NET Application</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
