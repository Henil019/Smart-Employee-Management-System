@model IEnumerable<EmployeeManagementSystem.Models.Department>
@{
    ViewBag.Title = "Departments";
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="display-6 fw-bold text-primary mb-0">
                <i class="bi bi-building me-2"></i>Departments
            </h2>
            <p class="text-muted mt-1">Manage company departments</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Dashboard", "Employee")" class="btn btn-outline-secondary px-4 py-2 shadow-sm rounded-3">
                <i class="bi bi-arrow-left me-1"></i> Dashboard
            </a>
            <a href="@Url.Action("Create")" class="btn btn-primary px-4 py-2 shadow-sm rounded-3">
                <i class="bi bi-plus-lg me-2"></i>Add New Department
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4 py-3 text-secondary fw-semibold">ID</th>
                            <th class="py-3 text-secondary fw-semibold">Department Name</th>
                            <th class="px-4 py-3 text-end text-secondary fw-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var d in Model)
                        {
                            <tr>
                                <td class="px-4 text-muted">#@d.Id</td>
                                <td class="fw-medium">@d.Name</td>
                                <td class="px-4 text-end">
                                    <div class="btn-group shadow-sm rounded-3">
                                        <a href="@Url.Action("Edit", new { id=d.Id })" class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", new { id=d.Id })" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
